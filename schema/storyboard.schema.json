{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AdsTurbo/adsturbo-creative-mcp/schema/storyboard.schema.json",
  "title": "AdsTurbo Creative MCP Storyboard",
  "type": "object",
  "required": ["platform", "durationSeconds", "aspectRatio", "scenes", "cta", "notes"],
  "properties": {
    "platform": {
      "type": "string",
      "enum": ["tiktok", "reels", "shorts", "meta", "youtube"]
    },
    "durationSeconds": { "type": "integer", "minimum": 15, "maximum": 90 },
    "aspectRatio": {
      "type": "string",
      "enum": ["9:16", "1:1", "16:9"]
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["start", "end", "visual", "caption", "voiceover", "purpose", "shotType", "productionNotes"],
        "properties": {
          "start": { "type": "integer", "minimum": 0 },
          "end": { "type": "integer", "minimum": 1 },
          "visual": { "type": "string" },
          "caption": { "type": "string" },
          "voiceover": { "type": "string" },
          "purpose": {
            "type": "string",
            "enum": ["hook", "product", "demo", "proof", "cta"]
          },
          "shotType": {
            "type": "string",
            "enum": ["close-up", "talking-head", "product-demo", "lifestyle", "hero-shot"]
          },
          "productionNotes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "cta": { "type": "string" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

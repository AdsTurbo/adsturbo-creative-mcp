{
  "name": "adsturbo-creative-mcp",
  "version": "0.1.2",
  "description": "A local-only MCP server and CLI for AI agents to create video ad briefs, hooks, UGC scripts, storyboards, reviews, and AdsTurbo-ready prompts.",
  "type": "module",
  "bin": {
    "adsturbo-creative": "dist/cli.js",
    "adsturbo-creative-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "schema",
    "examples",
    "docs",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/server.js",
    "test": "npm run build && node dist/smoke-test.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "adsturbo",
    "ai-agents",
    "ai-marketing",
    "ai-video",
    "ad-creative",
    "ad-brief",
    "ad-planning",
    "video-ads",
    "video-marketing",
    "ugc-ads",
    "ugc-scripts",
    "marketing-agents",
    "storyboard",
    "storyboard-generator",
    "prompt-engineering",
    "creative-automation",
    "claude-desktop",
    "codex",
    "cursor",
    "typescript",
    "nodejs",
    "cli"
  ],
  "author": "AdsTurbo",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdsTurbo/adsturbo-creative-mcp.git"
  },
  "homepage": "https://github.com/AdsTurbo/adsturbo-creative-mcp#readme",
  "bugs": {
    "url": "https://github.com/AdsTurbo/adsturbo-creative-mcp/issues"
  }
}
